    "cors": "^2.8.5",
    "dmdb": "^1.0.46190",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
