# 服务端口（前后端共用）
PORT=3000

# Node 环境
NODE_ENV=development

# 日志级别 (debug | info | warn | error)
LOG_LEVEL=info

# LLM 配置（统一接口）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4-plus
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=120000

# 达梦数据库（扩展工具 execute_sql，可选）
# DM_CONNECT_STRING=dm://SYSDBA:password@localhost:5236?autoCommit=false

# 档案 API（扩展工具 get_ai_archive_data，可选）
# ARCHIVE_API_BASE_URL=http://192.168.3.42:8085
# ARCHIVE_API_TOKEN=Bearer xxx
