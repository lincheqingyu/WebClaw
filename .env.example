# 网络配置（前后端共用）
HOST=0.0.0.0
BACKEND_PORT=3000
FRONTEND_PORT=5173

# 当前端与后端不在同源地址时，再取消注释覆盖
# 默认会根据当前页面地址和 BACKEND_PORT 自动推导 API / WS 地址
# BACKEND_ORIGIN=http://localhost:3000

# LLM 配置（保留必填项和常用项，其余使用内置默认值）
LLM_API_KEY=your-api-key-here
LLM_MODEL=glm-4-plus

# 可选运行参数：
# NODE_ENV=development
# LOG_LEVEL=info
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_TEMPERATURE=0.7  # 当前 schema 已声明，但默认调用链未读取
# LLM_MAX_TOKENS=8192
# LLM_TIMEOUT=120000   # 当前 schema 已声明，但默认调用链未读取

# 高级会话与上下文裁剪配置已有默认值，通常无需写入 .env

# PostgreSQL（记忆系统底座，可选；默认关闭）
# 本地 PG 验收环境：
#   1. pnpm pg:dev:start
#   2. 取消注释下面 6 项
#   3. pnpm --filter @lecquy/backend run db:migrate
#   4. pnpm --filter @lecquy/backend run pg:smoke
# PG_ENABLED=false
# PG_HOST=127.0.0.1
# PG_PORT=5432
# PG_DATABASE=lecquy
# PG_USER=postgres
# PG_PASSWORD=
# PG_POOL_MAX=10
# PG_SSL=false

# 达梦数据库（扩展工具 execute_sql，可选）
# DM_CONNECT_STRING=dm://SYSDBA:password@localhost:5236?autoCommit=false

# 档案 API（扩展工具 get_ai_archive_data，可选）
# ARCHIVE_API_BASE_URL=http://192.168.3.42:8085
# ARCHIVE_API_TOKEN=Bearer xxx
